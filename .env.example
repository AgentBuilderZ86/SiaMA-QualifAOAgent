# Ne pas réutiliser les identifiants de prod ici : le scan Netlify échoue si ces chaînes = secrets UI.
APP_USER_EMAIL=configure-login-email@example.invalid
APP_USER_PASSWORD=configure-strong-password-in-netlify-ui
SESSION_SECRET=replace-with-a-long-random-secret

# --- LLM : Anthropic (api.anthropic.com) ou OpenAI-compatible ---
# Si ANTHROPIC_API_KEY est défini, les appels passent par Messages API (sauf LLM_PROVIDER=openai).
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
# Limite de sortie (tokens) pour la qualification JSON longue ; sinon LLM_MAX_OUTPUT_TOKENS.
ANTHROPIC_MAX_OUTPUT_TOKENS=16384
# Forcer le fournisseur : anthropic | openai (optionnel).
# LLM_PROVIDER=anthropic

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1
# Clé générique si vous n'utilisez pas OPENAI_API_KEY
LLM_API_KEY=
LLM_MODEL=
LLM_MAX_OUTPUT_TOKENS=8192
LLM_QUALIFICATION_MAX_TOKENS=16384

GOOGLE_SHEET_ID=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# Optional: override tab names if your Sheet differs.
SHEET_AQ=A qualifier vs qualifié
SHEET_EC=En cours
SHEET_NG=NO GO
SHEET_PIPELINE=Pipeline BO-Propale

# --- Sources AO & pièces documentaires ---
# Rafraîchissement planifié des sources AO (Netlify Scheduled Function).
# Si renseigné, la route /api/refresh-ao-sources exige ce secret.
AO_REFRESH_SECRET=
AO_ENABLED_SOURCES=
# Exemples AO_ENABLED_SOURCES : Portail Marocain des Marches Publics,ADM Achats,ONDA Appels d'offres Achats
AO_SOURCE_MAX_PER_SOURCE=25
AO_INTEREST_KEYWORDS=architecture,amoa,conseil,cyber,data,digital,erp,gouvernance,pmo,sap,si,stratégie,transformation
AO_INTEREST_STATUSES=A QUALIFIER,BO,P2P
AO_INTEREST_MIN_SCORE=30
AO_DOCUMENT_SCRAPE_ON_REFRESH=false
AO_DOCUMENT_MAX_PER_AO=3
# OCR : tesseract (défaut, open source, sans config) | paddle | azure | none
# OCR_PROVIDER=tesseract

# --- PaddleOCR microservice (OCR_PROVIDER=paddle) ---
# Lancer le service : cd paddle_ocr_service && docker build -t paddle-ocr . && docker run -p 8070:8070 paddle-ocr
# PADDLE_OCR_URL=http://localhost:8070
# PADDLE_OCR_LANG=fr
# PADDLE_OCR_TIMEOUT_MS=30000

AO_DOCUMENT_CACHE_PATH=
BRIGHT_DATA_API_TOKEN=
BRIGHT_DATA_UNLOCKER_ZONE=
