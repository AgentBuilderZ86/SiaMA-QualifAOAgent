# Ne pas réutiliser les identifiants de prod ici : le scan Netlify échoue si ces chaînes = secrets UI.
APP_USER_EMAIL=configure-login-email@example.invalid
APP_USER_PASSWORD=configure-strong-password-in-netlify-ui
SESSION_SECRET=replace-with-a-long-random-secret

# --- LLM : Anthropic (api.anthropic.com) ou OpenAI-compatible ---
# Si ANTHROPIC_API_KEY est défini, les appels passent par Messages API (sauf LLM_PROVIDER=openai).
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
# Limite de sortie (tokens) pour la qualification JSON longue ; sinon LLM_MAX_OUTPUT_TOKENS.
ANTHROPIC_MAX_OUTPUT_TOKENS=16384
# Forcer le fournisseur : anthropic | openai (optionnel).
# LLM_PROVIDER=anthropic

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1
# Clé générique si vous n'utilisez pas OPENAI_API_KEY
LLM_API_KEY=
LLM_MODEL=
LLM_MAX_OUTPUT_TOKENS=8192
LLM_QUALIFICATION_MAX_TOKENS=16384

GOOGLE_SHEET_ID=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# Optional: override tab names if your Sheet differs.
SHEET_AQ=A qualifier vs qualifié
SHEET_EC=En cours
SHEET_NG=NO GO
SHEET_PIPELINE=Pipeline BO-Propale

# Deck qualification (/ao/.../qualification/deck) : auto = Python + template Sia si dispo, sinon pptxgenjs.
# Sur Netlify sans Python, laisser auto ou pptxgen. Installer : pip install -r requirements-deck.txt
QUALIFICATION_DECK_ENGINE=auto
# QUALIFICATION_DECK_PROFILE=standard
# QUALIFICATION_DECK_PYTHON_TIMEOUT_MS=90000
# PYTHON_BIN=python3
